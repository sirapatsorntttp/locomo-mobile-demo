# ============================================================
# LOCOMO — Transport Management System
# Copy ไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง
# ============================================================

# URL ของ NestJS Backend (ไม่มี trailing slash)
BACKEND_URL=http://localhost:4001

# Production:
# BACKEND_URL=https://api.your-company.com

# Next.js public vars (accessible in browser)
NEXT_PUBLIC_APP_NAME=LOCOMO
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_DEFAULT_LOCALE=th

# Google Maps API Key (สำหรับหน้า Tracking)
# NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaSy...

# Session secret (สำหรับ NextAuth ถ้าใช้งาน)
# NEXTAUTH_SECRET=your-secret-key
# NEXTAUTH_URL=http://localhost:3000
